# Android/Gradle build output and local machine config.
/build/
/app/build/
/.gradle/
/.kotlin/
local.properties

# Release signing: the keystore and its passwords must never be committed.
# Keep the keystore itself outside the repo entirely (see RELEASE-SIGNING.md);
# these patterns are a backstop in case one lands here by mistake.
keystore.properties
*.jks
*.keystore

# Prebuilt Rust core (per-ABI, produced by cargo-ndk) and the generated
# UniFFI bindings - both regenerated by the build steps in shells/README.md.
/app/src/main/jniLibs/
/app/src/main/java/uniffi/
