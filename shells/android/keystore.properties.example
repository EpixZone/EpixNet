# Copy this file to keystore.properties (which is gitignored) and fill in your
# real values. The build reads it to sign the release APK. Do NOT commit the
# filled-in file or the keystore itself.
#
# storeFile: absolute path to the keystore you generated. Keep it OUTSIDE the
# repo (e.g. ~/.epix/epix-release.jks) so it can never be committed.
# In a PKCS12 keystore (the keytool default) storePassword and keyPassword are
# the same value.
#
# See RELEASE-SIGNING.md for the one-time keytool command that creates this.

storeFile=/Users/you/.epix/epix-release.jks
storePassword=CHANGE_ME
keyAlias=epix-release
keyPassword=CHANGE_ME
