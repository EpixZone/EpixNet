<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+). Layers are prebuilt 432px PNGs from the
     assets repo (images/icons/generated/android/adaptive-*.png): flat #020202
     background, the Epix mark at 60% (inside the 66% safe zone), and a white
     silhouette for themed icons. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_monochrome" />
</adaptive-icon>
