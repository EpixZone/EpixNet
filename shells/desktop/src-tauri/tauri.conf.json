{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Epix",
  "version": "0.1.0",
  "identifier": "zone.epix.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Epix",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["epix"]
      }
    }
  }
}
